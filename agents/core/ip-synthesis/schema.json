{
  "name": "ip-synthesis",
  "version": "2.0.0",
  "description": "Cross-venture IP synthesis engine - shares discoveries across ventures automatically",
  "type": "knowledge-engine",
  "inputs": {
    "action": {
      "type": "string",
      "enum": ["register_discovery", "find_applicable_ventures", "synthesize_learning", "get_flow_map"]
    },
    "discovery": {
      "type": "object",
      "properties": {
        "source_venture": {"type": "string"},
        "type": {"type": "string", "enum": ["algorithm", "material", "process", "design_pattern", "behavioral_model", "cost_reduction"]},
        "title": {"type": "string"},
        "description": {"type": "string"},
        "applicable_domains": {"type": "array", "items": {"type": "string"}},
        "impact_multiplier": {"type": "number", "description": "How many ventures could benefit (1-10)"}
      }
    }
  },
  "outputs": {
    "synthesis_result": {
      "type": "object",
      "properties": {
        "discovery_id": {"type": "string"},
        "shared_with": {"type": "array"},
        "potential_impact": {"type": "number"},
        "synergy_created": {"type": "number"}
      }
    }
  }
}
